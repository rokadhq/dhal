{
  "name": "@rokadhq/dhal",
  "version": "1.0.1",
  "description": "Stable app-native WAF for Node.js with route-aware protection, distributed controls, runtime safety, production diagnostics, and a frozen v1 contract.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "dhal": "dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "require": "./dist/adapters/express.cjs"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.js",
      "require": "./dist/adapters/fastify.cjs"
    },
    "./node-http": {
      "types": "./dist/adapters/node-http.d.ts",
      "import": "./dist/adapters/node-http.js",
      "require": "./dist/adapters/node-http.cjs"
    },
    "./nest": {
      "types": "./dist/adapters/nest.d.ts",
      "import": "./dist/adapters/nest.js",
      "require": "./dist/adapters/nest.cjs"
    },
    "./koa": {
      "types": "./dist/adapters/koa.d.ts",
      "import": "./dist/adapters/koa.js",
      "require": "./dist/adapters/koa.cjs"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js",
      "require": "./dist/adapters/hono.cjs"
    },
    "./stores/redis": {
      "types": "./dist/stores/redis-rate-limit-store.d.ts",
      "import": "./dist/stores/redis-rate-limit-store.js",
      "require": "./dist/stores/redis-rate-limit-store.cjs"
    },
    "./reputation/abuseipdb": {
      "types": "./dist/reputation/abuseipdb.d.ts",
      "import": "./dist/reputation/abuseipdb.js",
      "require": "./dist/reputation/abuseipdb.cjs"
    },
    "./telemetry/otel": {
      "types": "./dist/telemetry/otel.d.ts",
      "import": "./dist/telemetry/otel.js",
      "require": "./dist/telemetry/otel.cjs"
    },
    "./telemetry/webhook": {
      "types": "./dist/telemetry/webhook.d.ts",
      "import": "./dist/telemetry/webhook.js",
      "require": "./dist/telemetry/webhook.cjs"
    },
    "./stores/memory-signal": {
      "types": "./dist/stores/memory-signal-store.d.ts",
      "import": "./dist/stores/memory-signal-store.js",
      "require": "./dist/stores/memory-signal-store.cjs"
    },
    "./stores/redis-signal": {
      "types": "./dist/stores/redis-signal-store.d.ts",
      "import": "./dist/stores/redis-signal-store.js",
      "require": "./dist/stores/redis-signal-store.cjs"
    },
    "./config-schema": {
      "types": "./dist/config-schema.d.ts",
      "import": "./dist/config-schema.js",
      "require": "./dist/config-schema.cjs"
    },
    "./autosetup": {
      "types": "./dist/autosetup/index.d.ts",
      "import": "./dist/autosetup/index.js",
      "require": "./dist/autosetup/index.cjs"
    },
    "./package.json": "./package.json",
    "./dhal.schema.json": "./dhal.schema.json",
    "./doctor": {
      "types": "./dist/doctor.d.ts",
      "import": "./dist/doctor.js",
      "require": "./dist/doctor.cjs"
    },
    "./rules/catalog": {
      "types": "./dist/rules/catalog.d.ts",
      "import": "./dist/rules/catalog.js",
      "require": "./dist/rules/catalog.cjs"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js",
      "require": "./dist/presets.cjs"
    },
    "./report": {
      "types": "./dist/report.d.ts",
      "import": "./dist/report.js",
      "require": "./dist/report.cjs"
    },
    "./compatibility": {
      "types": "./dist/compatibility.d.ts",
      "import": "./dist/compatibility.js",
      "require": "./dist/compatibility.cjs"
    },
    "./readiness": {
      "types": "./dist/readiness.d.ts",
      "import": "./dist/readiness.js",
      "require": "./dist/readiness.cjs"
    },
    "./migrations": {
      "types": "./dist/migrations.d.ts",
      "import": "./dist/migrations.js",
      "require": "./dist/migrations.cjs"
    },
    "./stability": {
      "types": "./dist/stability.d.ts",
      "import": "./dist/stability.js",
      "require": "./dist/stability.cjs"
    },
    "./v1-contract": {
      "types": "./dist/v1-contract.d.ts",
      "import": "./dist/v1-contract.js",
      "require": "./dist/v1-contract.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY_NOTES.md",
    "dhal.schema.json",
    "RELEASE_INTEGRITY.md",
    "LICENSE",
    "SECURITY.md",
    "SUPPORT_POLICY.md",
    "PRODUCTION_DEPLOYMENT.md",
    "CHANGELOG.md",
    "V1_READINESS.md",
    "API_STABILITY.md",
    "UPGRADING.md",
    "PUBLISHING.md",
    "V1_CONTRACT.md",
    "V1_RELEASE_PLAN.md",
    "V1_1_PLAN.md",
    "NESTJS.md",
    "KOA_HONO.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/config-schema.ts src/doctor.ts src/rules/catalog.ts src/presets.ts src/report.ts src/readiness.ts src/compatibility.ts src/stability.ts src/migrations.ts src/v1-contract.ts src/adapters/express.ts src/adapters/fastify.ts src/adapters/node-http.ts src/adapters/nest.ts src/adapters/koa.ts src/adapters/hono.ts src/stores/redis-rate-limit-store.ts src/stores/redis-signal-store.ts src/stores/memory-signal-store.ts src/reputation/abuseipdb.ts src/telemetry/otel.ts src/telemetry/webhook.ts src/autosetup/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "dev:express": "tsx examples/express.ts",
    "dev:fastify": "tsx examples/fastify.ts",
    "simulate": "tsx src/cli.ts simulate fixtures.simulation.json",
    "test": "vitest run",
    "benchmark": "tsx bench/bench.ts",
    "schema": "tsx src/cli.ts schema dhal.schema.json",
    "ci:config": "tsx src/cli.ts ci",
    "verify:exports": "node scripts/verify-package-exports.mjs",
    "verify:packed": "node scripts/verify-packed-package.mjs",
    "verify:performance": "node --expose-gc --import tsx bench/release-budget.ts",
    "verify:supply-chain": "node scripts/generate-release-assets.mjs --verify-only",
    "release:assets": "node scripts/generate-release-assets.mjs",
    "release:check": "tsx src/cli.ts release-check --target stable --require-build",
    "release:check:rc": "tsx src/cli.ts release-check --target rc --require-build",
    "release:check:stable": "tsx src/cli.ts release-check --target stable --require-build",
    "verify:publish": "npm run typecheck && npm test && npm run build && npm run schema && npm run verify:exports && npm run ci:config && npm run simulate && npm audit --omit=dev",
    "verify:v1": "npm run verify:publish && npm run verify:packed && npm run verify:performance && npm run verify:supply-chain && npm run release:check",
    "pack:dry": "npm pack --dry-run",
    "pack:release": "npm run verify:v1 && npm pack",
    "prepublishOnly": "npm run verify:v1",
    "doctor": "node -e \"console.log(`node ${process.version}`); console.log(`npm ${process.env.npm_config_user_agent || 'unknown'}`)\"",
    "publish:local": "npm publish --tag latest --access public --provenance=false",
    "publish:ci": "npm publish --tag latest --access public",
    "release:check:development": "tsx src/cli.ts release-check --target development --require-build"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.8.0",
    "express": ">=4.18.0 || >=5.0.0",
    "fastify": ">=4.0.0 || >=5.0.0",
    "ioredis": ">=5.0.0",
    "ai": ">=5.0.0",
    "@ai-sdk/openai": ">=2.0.0",
    "@ai-sdk/anthropic": ">=2.0.0",
    "@ai-sdk/google": ">=2.0.0",
    "@ai-sdk/mistral": ">=2.0.0",
    "@ai-sdk/xai": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/mistral": {
      "optional": true
    },
    "@ai-sdk/xai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "express": "^4.18.3",
    "fastify": "^5.8.5",
    "ioredis": "^5.3.2",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "author": "Aryabh Thakur",
  "keywords": [
    "waf",
    "web-application-firewall",
    "nodejs",
    "security",
    "middleware",
    "express",
    "fastify",
    "nestjs",
    "koa",
    "hono",
    "rate-limit",
    "bot-defense",
    "credential-stuffing",
    "opentelemetry",
    "ai-sdk",
    "application-security"
  ],
  "sideEffects": false,
  "packageManager": "npm@10.9.2",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rokadhq/dhal.git"
  },
  "bugs": {
    "url": "https://github.com/rokadhq/dhal/issues"
  },
  "homepage": "https://rokad.co/en/open-source/dhal"
}
